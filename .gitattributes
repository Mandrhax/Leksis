# Enforce LF line endings in the repository for all text files.
# This ensures shell scripts work correctly on Linux servers
# regardless of the developer's OS.

* text=auto eol=lf

# Shell scripts — must be LF, never CRLF
*.sh text eol=lf

# SQL files
*.sql text eol=lf

# Web source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf

# Docker
Dockerfile    text eol=lf
.dockerignore text eol=lf
