# ============================================================
# Leksis — Production Environment Variables
#
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git — it is listed in .gitignore.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
# Password for the leksis_user PostgreSQL account.
# Used by docker-compose to create the user AND assembled into DATABASE_URL.
POSTGRES_PASSWORD=change_me_strong_password

# PostgreSQL major version (e.g. 18, 17, 16).
# WARNING: changing this on an existing install requires a data migration (pg_upgrade or dump/restore).
POSTGRES_VERSION=18

# Full connection string — keep the password in sync with POSTGRES_PASSWORD above.
# The hostname "postgres" resolves via the internal Docker network.
DATABASE_URL=postgresql://leksis_user:change_me_strong_password@postgres:5432/leksis

# ── NextAuth ─────────────────────────────────────────────────
# Random secret used to sign session tokens.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_openssl_rand_base64_32_output

# Public URL of the application (no trailing slash).
# Must match CADDY_HOST with protocol prefix — no port needed (Caddy uses 80/443).
# HTTP (bare IP):  NEXTAUTH_URL=http://192.168.1.10
# HTTPS (domain):  NEXTAUTH_URL=https://leksis.yourdomain.com
NEXTAUTH_URL=https://leksis.yourdomain.com

# ── Caddy Reverse Proxy ──────────────────────────────────────
# Hostname or IP address Caddy listens on (no protocol, no port).
# Bare IP  → HTTP only, no TLS (intranet / bare-metal)
# Domain   → HTTPS with automatic Let's Encrypt (port 443 must be reachable)
# Examples:
#   CADDY_HOST=192.168.1.10
#   CADDY_HOST=leksis.yourdomain.com
CADDY_HOST=leksis.yourdomain.com

# ── Encryption ───────────────────────────────────────────────
# AES-256-GCM key — exactly 64 hexadecimal characters (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_hex_char_string

# ── Ollama ───────────────────────────────────────────────────
# Resolved via the internal Docker network — do not change unless
# you are running Ollama outside of docker-compose.
OLLAMA_BASE_URL=http://ollama:11434

# Model names — must be pulled on the Ollama container before use.
# The install.sh script handles this automatically.
OLLAMA_MODEL=translategemma:27b
OLLAMA_OCR_MODEL=maternion/LightOnOCR-2:latest
OLLAMA_REWRITE_MODEL=qwen2.5:14b

# Ollama runtime settings
# How long to keep models loaded in VRAM (-1 = forever, 5m = 5 min, 0 = unload immediately)
OLLAMA_KEEP_ALIVE=-1
# Spread model layers across multiple GPUs (set to number of GPUs, or false to disable)
OLLAMA_SCHED_SPREAD=4
# Maximum number of models loaded simultaneously
OLLAMA_MAX_LOADED_MODELS=3
